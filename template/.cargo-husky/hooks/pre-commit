#!/bin/sh
# Pre-commit hook: format staged files using their language-specific
# formatters.  Runs each formatter only on the staged files that match
# its file extension, then re-stages the formatted versions.

set -e

# Collect staged filenames (Added, Copied, or Modified only).
STAGED=$(git diff --staged --name-only --diff-filter=ACM || true)

if [ -z "$STAGED" ]; then
  exit 0
fi

# Filter staged files by extension pattern.
staged_matching() {
  echo "$STAGED" | grep "$1" || true
}

STAGED_RS=$(staged_matching '\.rs$')
STAGED_NIX=$(staged_matching '\.nix$')
STAGED_ELM=$(staged_matching '\.elm$')
STAGED_CSS=$(staged_matching '\.css$')

formatted=false

if [ -n "$STAGED_RS" ]; then
  echo "Formatting staged Rust files..."
  for f in $STAGED_RS; do
    echo "  - $f"
    rustfmt --edition 2021 "$f"
    git add "$f"
  done
  formatted=true
fi

if [ -n "$STAGED_NIX" ]; then
  echo "Formatting staged Nix files..."
  for f in $STAGED_NIX; do
    echo "  - $f"
    alejandra -q "$f"
    git add "$f"
  done
  formatted=true
fi

if [ -n "$STAGED_ELM" ]; then
  echo "Formatting staged Elm files..."
  for f in $STAGED_ELM; do
    echo "  - $f"
    elm-format --yes "$f"
    git add "$f"
  done
  formatted=true
fi

if [ -n "$STAGED_CSS" ]; then
  echo "Formatting staged CSS files..."
  for f in $STAGED_CSS; do
    echo "  - $f"
    prettier --write "$f"
    git add "$f"
  done
  formatted=true
fi

if [ "$formatted" = true ]; then
  echo "Staged files formatted and re-staged successfully."
else
  echo "No formattable files staged for commit."
fi
